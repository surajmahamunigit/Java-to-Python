########################## Dictionary ##########################

########## Properties ##########

# if we want key value pair then we can use dictionary
# insertion order is not preserved in dictionary
# indexing and slicing is not possible in dictionary
# duplicate keys are not allowed in dictionary but duplicate values are allowed
# heterogeneous key and values are allowed in dictionary
# dictionary is mutable data structure
# it is dymamic data structure
# d= {k1:v1, k2:v2, k3:v3, k4:v4}


########## Creation of Dictionary ##########

# d={} # empty dictionary
# d=dict() # empty dictionary
# d={1:'one', 2:'two', 3:'three'} # dictionary with integer keys and string values
# d={'name':'john', 'age':30, 'city':'new york'} # dictionary with string keys and heterogeneous values
# d={1:'one', 'two':2, 3.0:'three'} # dictionary with heterogeneous keys and values

# we can create dict from list of tuples
# l=[('name','john'), ('age',30), ('city','new york')]
# d=dict(l) # dictionary with string keys and heterogeneous values

# we can create dict from list of lists
# l=[['name','john'], ['age',30], ['city','new york']]
# d=dict(l) # dictionary with string keys and heterogeneous values

# we can create dict from tuple of tuples
# t=(('name','john'), ('age',30), ('city','new york'))
# d=dict(t) # dictionary with string keys and heterogeneous values

# we can create dict from tuple of lists
# t=(['name','john'], ['age',30], ['city','new york']) 
# d=dict(t) # dictionary with string keys and heterogeneous values

# we can create dict from set of tuples
# s={('name','john'), ('age',30), ('city','new york')}
# d=dict(s) # dictionary with string keys and heterogeneous values

## we """can't""" create dict from set of lists
# s={['name','john'], ['age',30], ['city','new york']} # TypeError: unhashable type: 'list'

#Note: we can have tuple of tuples, tuple of lists, list of tuples, list of lists, set of tuples only with two elements. by chance if we have more than two elements then we will get ValueError: dictionary update sequence element #0 has length 3; 2 is required

